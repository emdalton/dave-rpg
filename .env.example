# DAVE RPG Environment Configuration Template
# ============================================
# Copy this file to dave-rpg.env and fill in your values.
# NEVER commit dave-rpg.env to git - it contains secrets!
#
# Generate a secret key with:
#   python3 -c "import secrets; print(secrets.token_hex(32))"

# =============================================================================
# LLM BACKEND SELECTION
# =============================================================================
# Choose ONE backend and uncomment its settings:

# --- Option 1: Scaleway Generative APIs (Recommended for production) ---
DAVE_LLM_BACKEND=scaleway
DAVE_SCALEWAY_MODEL=mistral/mistral-small-3.2-24b-instruct-2506:fp8
# Get your key from: https://console.scaleway.com/iam/api-keys
SCW_SECRET_KEY=your_scaleway_api_key_here
# DAVE_SCALEWAY_API_KEY=your_scaleway_api_key_here  # Alternative env var name

# --- Option 2: Ollama (Local inference, requires GPU/Apple Silicon) ---
# DAVE_LLM_BACKEND=ollama
# DAVE_OLLAMA_BASE_URL=http://localhost:11434
# DAVE_OLLAMA_MODEL=mistral
# DAVE_OLLAMA_TIMEOUT=120

# --- Option 3: Anthropic Claude (Phase 1 prototyping) ---
# DAVE_LLM_BACKEND=claude
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# DAVE_CLAUDE_MODEL=claude-haiku-4-5-20251001
# DAVE_CLAUDE_MAX_TOKENS=2048

# =============================================================================
# WEB FRONTEND CONFIGURATION
# =============================================================================
DAVE_SECRET_KEY=REPLACE_WITH_GENERATED_KEY
DAVE_DEBUG=0
DAVE_WEB_PORT=8001

# User database paths (absolute paths recommended for systemd)
DAVE_USER_DB_PATH=/home/ubuntu/dave-rpg/web/dave_users.db
DAVE_USER_DB_DIR=/home/ubuntu/dave-rpg/user_dbs

# User limits
DAVE_MAX_USERS=10
DAVE_MAX_TURNS=50
DAVE_BUDGET_EUROS=1.0

# Token pricing for budget tracking (update for your model)
# Mistral Small 3.2 (Scaleway): €0.15/1M input, €0.35/1M output
DAVE_PRICE_INPUT_PER_M=0.15
DAVE_PRICE_OUTPUT_PER_M=0.35

# Cloudflare Turnstile CAPTCHA
# Test keys (always pass) - replace with real keys for production
# Get keys from: https://dash.cloudflare.com/?to=/:account/turnstile
DAVE_TURNSTILE_SITE_KEY=1x00000000000000000000AA
DAVE_TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA

# Contact URL shown when limits are reached
DAVE_CONTACT_URL=https://www.linkedin.com/in/elizabethdalton/

# =============================================================================
# ENGINE CONFIGURATION
# =============================================================================
DAVE_LOG_LEVEL=WARNING
# DAVE_LOG_LEVEL=DEBUG  # Use for troubleshooting

# Tuning parameters
DAVE_LLM_MAX_RETRIES=3
DAVE_ACTION_LOG_MAX_ROWS=50
DAVE_PASS1_RECENT_ACTIONS=5
DAVE_PASS2_MAX_LOCATION_DETAILS=10
DAVE_PASS2_MAX_ITEMS=12

# Game mechanics tuning
DAVE_INVOLUNTARY_MAX_PROB=0.25
DAVE_WANDER_SLEEPINESS_THRESHOLD=0.60
DAVE_ACTIVITY_AUTO_CLEAR_CONFIDENCE=0.60
